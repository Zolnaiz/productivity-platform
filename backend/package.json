{
  "name": "questionnaire-backend",
  "version": "1.0.0",
  "description": "Асуулга, зардлын менежментийн системийн backend",
  "author": "Your Name",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm migration:generate -- -d src/migrations/data-source.ts",
    "migration:run": "npm run typeorm migration:run -- -d src/migrations/data-source.ts",
    "migration:revert": "npm run typeorm migration:revert -- -d src/migrations/data-source.ts",
    "migration:create": "npm run typeorm migration:create",
    "db:up": "docker compose -f docker-compose.db.yml up -d postgres",
    "db:down": "docker compose -f docker-compose.db.yml down",
    "db:logs": "docker compose -f docker-compose.db.yml logs -f postgres",
    "seed": "ts-node --transpile-only scripts/seed-operations.ts",
    "token:smoke": "ts-node --transpile-only scripts/create-smoke-token.ts",
    "smoke:api": "ts-node --transpile-only scripts/smoke-operations-api.ts",
    "docker:build": "docker build -t questionnaire-backend .",
    "docker:run": "docker run -p 3000:3000 questionnaire-backend",
    "docker:compose": "docker-compose up",
    "docker:compose:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:compose:prod": "docker-compose -f docker-compose.prod.yml up",
    "prepare": "husky install"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/platform-socket.io": "^11.1.9",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.8.1",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.17",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.9",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.1",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-local": "^1.0.35",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "ts",
      "json",
      "js"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@app/(.*)$": "<rootDir>/$1",
      "^@shared/(.*)$": "<rootDir>/shared/$1",
      "^@auth/(.*)$": "<rootDir>/auth/$1",
      "^@users/(.*)$": "<rootDir>/users/$1",
      "^@organizations/(.*)$": "<rootDir>/organizations/$1",
      "^@questionnaires/(.*)$": "<rootDir>/questionnaires/$1",
      "^@responses/(.*)$": "<rootDir>/responses/$1",
      "^@expenses/(.*)$": "<rootDir>/expenses/$1",
      "^@reports/(.*)$": "<rootDir>/reports/$1"
    }
  }
}
