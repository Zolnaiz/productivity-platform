# Application Configuration
APP_NAME="Productivity Platform"
APP_VERSION="1.0.0"
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:3001"
BACKEND_URL="http://localhost:3000"

# Database Configuration
DB_HOST="localhost"
DB_PORT=5432
DB_USERNAME="postgres"
DB_PASSWORD="postgres"
DB_DATABASE="questionnaire_db"
DB_SYNCHRONIZE="false"
DB_LOGGING="false"
DB_SSL="false"
DB_MIGRATIONS_RUN="true"

# Local demo smoke option:
# Set DB_SYNCHRONIZE="true" and ALLOW_PUBLIC_OPERATIONS="true" only for throwaway local databases.

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# Security Configuration
BCRYPT_ROUNDS=10
CORS_ORIGINS="http://localhost:3001,http://localhost:5173,http://127.0.0.1:5173"
ENABLE_SWAGGER="false"
ALLOW_PUBLIC_OPERATIONS="false"
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES="image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
UPLOAD_PATH="./uploads"

# Email Configuration (Optional)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_SECURE="false"
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_FROM="noreply@questionnaire.com"

# Redis Configuration (Optional)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_TTL=3600

# Monitoring Configuration (Optional)
SENTRY_DSN=""
ENABLE_METRICS="false"
METRICS_PORT=9090

# Third-party Services (Optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""

# Feature Flags
ENABLE_REGISTRATION="true"
ENABLE_EMAIL_VERIFICATION="false"
ENABLE_SOCIAL_LOGIN="false"
ENABLE_TWO_FACTOR="false"
ENABLE_API_DOCS="true"

# Business Rules
MAX_QUESTIONNAIRES_PER_ORG=100
MAX_QUESTIONS_PER_QUESTIONNAIRE=50
MAX_EXPENSE_AMOUNT=1000000000
REPORT_RETENTION_DAYS=365
PASSWORD_MIN_LENGTH=8

# Logging Configuration
LOG_LEVEL="debug"
LOG_FILE="logs/app.log"
LOG_MAX_FILES=14
LOG_MAX_SIZE="20m"
