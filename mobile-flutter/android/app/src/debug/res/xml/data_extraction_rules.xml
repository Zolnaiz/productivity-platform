<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include for cloud backup -->
        <include domain="file" path="." />
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
        <include domain="external" path="." />
        
        <!-- Exclude debug specific files -->
        <exclude domain="file" path="debug_data/" />
        <exclude domain="sharedpref" path="debug_prefs.xml" />
    </cloud-backup>
    
    <device-transfer>
        <!-- Include for device transfer -->
        <include domain="file" path="." />
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
        
        <!-- Exclude large files -->
        <exclude domain="file" path="large_cache/" />
    </device-transfer>
</data-extraction-rules>