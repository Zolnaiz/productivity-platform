DB_USERNAME=productivity_prod
DB_PASSWORD=replace-with-a-long-random-password
DB_DATABASE=productivity_prod
DB_PORT=5432

API_PORT=3000
WEB_PORT=3001
CORS_ORIGINS=https://app.example.com
VITE_API_URL=https://api.example.com/api
VITE_ENABLE_DEMO_MODE=false

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-32-random-characters-or-leave-empty
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

DB_MIGRATIONS_RUN=true
DB_LOGGING=false
DB_SSL=false
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=120
ENABLE_METRICS=false

REDIS_PASSWORD=replace-with-a-long-random-redis-password
GRAFANA_PASSWORD=replace-with-a-long-random-grafana-password
BACKUP_SCHEDULE=@daily
